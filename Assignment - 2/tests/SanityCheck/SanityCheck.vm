// SanityCheck(W_rows, W_cols, X_rows, X_cols, B_rows, B_cols)
// Arguments:
//   argument 0 = W_rows
//   argument 1 = W_cols
//   argument 2 = X_rows
//   argument 3 = X_cols
//   argument 4 = B_rows
//   argument 5 = B_cols
//
// Returns 1 if dimensions are compatible, -1 otherwise.
// Also writes the return value to static 0 - ERROR_LOC

function SanityCheck.check 0

    // Check 1: W_cols must equal X_rows
    push argument 1
    push argument 2
    sub
    if-goto DIMENSION_MISMATCH

    // Check 2: B_rows must equal W_rows
    push argument 4
    push argument 0
    sub
    if-goto DIMENSION_MISMATCH

    // All good - set ERROR_LOC = 1 and return 1
    push constant 1
    pop static 0
    push constant 1
    return

label DIMENSION_MISMATCH
    // Bad dimensions - set ERROR_LOC = -1 and return -1
    push constant 1
    neg
    pop static 0
    push constant 1
    neg
    return
