/**
 * Exclusive-or gate:
 * if ((a and Not(b)) or (Not(a) and b)) out = 1, else out = 0
 */
CHIP Xor {
    IN a , b ;
    OUT out ;
    PARTS :
    Nand ( a =a , b =b , out = nand1 ) ;
    Nand ( a =a , b = nand1 , out = nand2 ) ;
    Nand ( a = nand1 , b =b , out = nand3 ) ;
    Nand ( a = nand2 , b = nand3 , out = out ) ;
}