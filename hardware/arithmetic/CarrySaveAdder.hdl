CHIP CarrySaveAdder {
    IN x[32], y[32], z[32];
    OUT sum[32], carry[32];

    PARTS:
    Or(a=false, b=false, out=carry[0]);

    FullAdder(a=x[0], b=y[0], c=z[0], sum=sum[0], carry=carry[1]);
    FullAdder(a=x[1], b=y[1], c=z[1], sum=sum[1], carry=carry[2]);
