    FullAdder(a=x[15], b=y[15], c=z[15], sum=sum[15], carry=carry[16]);
    FullAdder(a=x[16], b=y[16], c=z[16], sum=sum[16], carry=carry[17]);
    FullAdder(a=x[17], b=y[17], c=z[17], sum=sum[17], carry=carry[18]);
    FullAdder(a=x[18], b=y[18], c=z[18], sum=sum[18], carry=carry[19]);
