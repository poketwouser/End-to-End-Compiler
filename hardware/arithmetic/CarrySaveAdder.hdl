    FullAdder(a=x[23], b=y[23], c=z[23], sum=sum[23], carry=carry[24]);
    FullAdder(a=x[24], b=y[24], c=z[24], sum=sum[24], carry=carry[25]);
    FullAdder(a=x[25], b=y[25], c=z[25], sum=sum[25], carry=carry[26]);
    FullAdder(a=x[26], b=y[26], c=z[26], sum=sum[26], carry=carry[27]);
    FullAdder(a=x[27], b=y[27], c=z[27], sum=sum[27], carry=carry[28]);
